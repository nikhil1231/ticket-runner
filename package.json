{
  "name": "ticket-runner",
  "version": "0.1.0",
  "private": true,
  "description": "Polls Notion boards for AI-flagged tickets and completes them with a coding CLI (codex/antigravity) in a git worktree.",
  "main": "runner.js",
  "scripts": {
    "start": "node runner.js",
    "once": "node runner.js once",
    "dry": "node runner.js once --dry-run",
    "setup:notion": "node scripts/setup-notion.js",
    "setup:github": "node scripts/setup-github.js",
    "setup:service": "node scripts/install-service.js",
    "healthcheck": "node runner.js healthcheck",
    "supervise": "node scripts/supervisor.js",
    "cleanup": "node runner.js cleanup",
    "test": "node --test test/*.test.js"
  },
  "engines": {
    "node": ">=22.5"
  }
}
