# Notion internal integration token (create at https://www.notion.so/my-integrations,
# then connect the integration to both board pages via ... menu > Connections).
# Required only while any project (or the incubator) still uses a Notion tracker.
NOTION_TOKEN=ntn_xxx

# GitHub PAT (fine-grained or classic) with repo + Projects read/write on the target
# repos. Required only for projects whose tracker.type is "github".
GITHUB_TOKEN=ghp_xxx

# Expo access token, required only for projects that publish with eas-update.
EXPO_TOKEN=

# Set to 1 (the service unit does this) to allow guarded self-healing.
TICKET_RUNNER_SUPERVISED=0
